rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // The app signs in anonymously after the PIN screen, so every legitimate
    // request carries an auth token. Block anything without one (bots, scrapers,
    // direct API calls that never went through the app).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
